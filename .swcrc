{
    "jsc": {
      "parser": {
        "syntax": "typescript",
        "tsx": false,
        "decorators": true
      },
      "target": "es2022",
      "loose": false,
      "externalHelpers": true,
      "keepClassNames": true
    },
    "module": {
      "type": "commonjs"
    },
    "sourceMaps": true
  }
  